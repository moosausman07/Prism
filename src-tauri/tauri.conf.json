{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "prism",
  "version": "0.1.0",
  "identifier": "com.moosa.prism",
  "build": {
    "beforeDevCommand": "dx serve --port 1420 --interactive false",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "dx bundle --release",
    "frontendDist": "../dist/public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "prism",
        "width": 820,
        "height": 540,
        "center": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
